{
  "name": "ason-js",
  "version": "1.0.0",
  "description": "ASON (Array-Schema Object Notation) – high-performance, schema-driven data format for JS/TS",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly && node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ason-lab/ason-js.git",
    "directory": "ason-js"
  },
  "homepage": "https://github.com/ason-lab/ason-js#readme",
  "bugs": {
    "url": "https://github.com/ason-lab/ason-js/issues"
  },
  "keywords": [
    "ason",
    "serialization",
    "schema",
    "llm",
    "data-format"
  ],
  "sideEffects": false
}
